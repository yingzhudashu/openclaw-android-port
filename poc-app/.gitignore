# ==========================================
# OpenClaw Android - .gitignore
# ==========================================

# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
*.iws
*.ipr

# Keystore files
*.jks
*.keystore
!app/debug.keystore

# External native build folder generated in Android Studio 2.2 and later
.cxx/
.externalNativeBuild/

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Kotlin
.kotlin/
*.kotlin_metadata

# Version control
*.orig
*.rej

# NDK
*.o
*.a
*.so
!app/src/main/jniLibs/

# Crashlytics
crashlytics-build.properties
fabric/

# Profiling
*.hprof

# Patch files
*.patch

# OpenClaw runtime data (DO NOT commit)
app/src/main/assets/openclaw-engine/openclaw.json
app/src/main/assets/openclaw-engine/sessions/
app/src/main/assets/openclaw-engine/memory/
app/src/main/assets/openclaw-engine/MEMORY.md
app/src/main/assets/openclaw-engine/cron_tasks.json
app/src/main/assets/openclaw-engine/photos/

# Temporary files
tmp/
temp/
*.tmp
*.swp
*.swo
*~

# APK signing
release/
*.keystore
*.jks
