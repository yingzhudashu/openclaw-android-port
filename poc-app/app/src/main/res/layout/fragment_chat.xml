<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_theme_surface">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/topbar_bg"
        android:elevation="2dp"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:gravity="center_vertical">

        <!-- 会话 ID（短） -->
        <TextView
            android:id="@+id/tvSessionId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#--------"
            android:textSize="11sp"
            android:textColor="@color/timestamp_light"
            android:fontFamily="monospace"
            android:layout_marginEnd="8dp" />

        <!-- 会话标题 -->
        <TextView
            android:id="@+id/tvSessionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/chat_new_session"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- 工具数 -->
        <TextView
            android:id="@+id/tvToolCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:textColor="@color/timestamp_light"
            android:layout_marginEnd="8dp" />

        <!-- 会话列表 -->
        <ImageButton
            android:id="@+id/btnSessionList"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="2dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_session_list"
            android:scaleType="centerInside"
            app:tint="@color/md_theme_primary" />

        <!-- 新建会话（加号） -->
        <ImageButton
            android:id="@+id/btnNewSession"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_new_session"
            android:scaleType="centerInside"
            app:tint="@color/md_theme_primary" />
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/topbar_divider" />

    <!-- 消息列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        android:overScrollMode="never" />

    <!-- 底部输入栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="bottom"
        android:background="@color/topbar_bg"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnAttach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="4dp"
            android:src="@android:drawable/ic_menu_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_attach"
            android:scaleType="centerInside"
            app:tint="@color/attach_btn" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/input_stroke"
            app:cardBackgroundColor="@color/topbar_bg">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_message"
                android:inputType="textMultiLine"
                android:maxLines="5"
                android:minHeight="42dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:background="@android:color/transparent"
                android:textSize="15sp"
                android:textColorHint="@color/timestamp_light" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="@string/content_desc_send"
            app:fabSize="mini"
            app:fabCustomSize="42dp"
            app:backgroundTint="@color/md_theme_primary"
            app:tint="@color/md_theme_on_primary"
            app:elevation="2dp" />
    </LinearLayout>

</LinearLayout>
