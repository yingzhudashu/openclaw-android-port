<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- 椤堕儴鏍?-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/topbar_bg"
        android:elevation="2dp"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:gravity="center_vertical">

        <!-- 浼氳瘽 ID锛堢煭锛?-->
        <TextView
            android:id="@+id/tvSessionId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#--------"
            android:textSize="11sp"
            android:textColor="@color/timestamp_light"
            android:fontFamily="monospace"
            android:layout_marginEnd="8dp" />

        <!-- Network status bar -->
        <TextView
            android:id="@+id/tvSessionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/chat_new_session"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- 宸ュ叿鏁?-->
        <TextView
            android:id="@+id/tvToolCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:textColor="@color/timestamp_light"
            android:layout_marginEnd="8dp" />

        <!-- 浼氳瘽鍒楄〃 -->
        <ImageButton
            android:id="@+id/btnSessionList"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="2dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_session_list"
            android:scaleType="centerInside"
            app:tint="@color/fab_bg" />

        <!-- 鏂板缓浼氳瘽锛堝姞鍙凤級 -->
        <ImageButton
            android:id="@+id/btnNewSession"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_new_session"
            android:scaleType="centerInside"
            app:tint="@color/fab_bg" />

        <!-- 璁板繂鎼滅储 -->
        <ImageButton
            android:id="@+id/btnMemorySearch"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="2dp"
            android:src="@android:drawable/ic_menu_search"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_memory_search"
            android:scaleType="centerInside"
            app:tint="@color/fab_bg" />
    </LinearLayout>

    <!-- Memory Search Overlay -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#F5F5F5"
        android:elevation="1dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="@string/search_hint"
            android:textSize="14sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@android:drawable/edit_text"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:maxLines="1"
            android:textColorHint="@color/timestamp_light" />

        <ImageButton
            android:id="@+id/btnSearchClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/search_close"
            android:scaleType="centerInside"
            app:tint="@color/fab_bg" />
    </LinearLayout>

    <!-- 鍒嗗壊绾?-->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/topbar_divider" />

    <!-- 缃戠粶鐘舵€佹í骞?-->
    <TextView
        android:id="@+id/tvNetworkBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F44336"
        android:text="@string/network_disconnected"
        android:textColor="@color/bubble_user_text"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone" />

    <!-- 娑堟伅鍒楄〃 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        android:overScrollMode="never" />

    <!-- 搴曢儴杈撳叆鏍?-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="bottom"
        android:background="@color/topbar_bg"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnAttach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="4dp"
            android:src="@android:drawable/ic_menu_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_attach"
            android:scaleType="centerInside"
            app:tint="@color/attach_btn" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/input_stroke"
            app:cardBackgroundColor="@color/topbar_bg">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_message"
                android:inputType="textMultiLine"
                android:maxLines="5"
                android:minHeight="42dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:background="@android:color/transparent"
                android:textSize="15sp"
                android:textColorHint="@color/timestamp_light" />
        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_send"
            android:contentDescription="@string/content_desc_send"
            app:fabSize="mini"
            app:fabCustomSize="42dp"
            app:backgroundTint="@color/fab_bg"
            app:tint="@color/fab_icon"
            app:elevation="2dp" />
    </LinearLayout>

</LinearLayout>