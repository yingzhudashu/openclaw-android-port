<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- 日期分隔线 -->
    <TextView
        android:id="@+id/tvDateSeparator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:background="@drawable/date_separator_bg"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <!-- 用户消息（靠右） -->
    <LinearLayout
        android:id="@+id/layoutUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:paddingStart="72dp"
        android:paddingEnd="12dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone">

        <!-- 图片消息（微信风格：圆角、无边框） -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUserImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:strokeWidth="0dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivUserImage"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:maxHeight="180dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter" />
        </com.google.android.material.card.MaterialCardView>

        <!-- 文件消息（微信风格：白底卡片） -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUserFile"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            app:cardCornerRadius="8dp"
            app:cardElevation="1dp"
            app:strokeWidth="0.5dp"
            app:strokeColor="#E0E0E0"
            app:cardBackgroundColor="#FFFFFF"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:id="@+id/tvUserFileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:maxLines="2"
                        android:ellipsize="middle" />

                    <TextView
                        android:id="@+id/tvUserFileSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvFileIcon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="📄"
                    android:textSize="24sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 文本消息气泡 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            app:cardCornerRadius="18dp"
            app:cardElevation="1dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/bubble_user">

            <TextView
                android:id="@+id/tvUserMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:textColor="@color/bubble_user_text"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvUserTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="6dp"
            android:textSize="10sp"
            android:textColor="@color/timestamp_light" />

        <TextView
            android:id="@+id/tvRetryHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="6dp"
            android:text="@string/chat_send_failed_retry"
            android:textSize="12sp"
            android:textColor="#F44336"
            android:visibility="gone" />

    </LinearLayout>

    <!-- AI 消息（靠左） -->
    <LinearLayout
        android:id="@+id/layoutAi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="48dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone">

        <!-- AI 头像（点击可改） -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/avatar_bg"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvAvatarEmoji"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🦞"
                android:textSize="16sp" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- AI 名字标签 -->
            <TextView
                android:id="@+id/tvAiLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OpenClaw"
                android:textSize="11sp"
                android:textColor="@color/label_text"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0.5dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/bubble_ai">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 工具调用折叠区 -->
                    <LinearLayout
                        android:id="@+id/layoutToolLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:visibility="gone"
                        android:background="@color/tool_log_bg">

                        <TextView
                            android:id="@+id/tvToolSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/tool_log_text" />

                        <TextView
                            android:id="@+id/tvToolDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/tool_log_detail"
                            android:fontFamily="monospace"
                            android:paddingTop="4dp"
                            android:paddingBottom="6dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- AI 图片 -->
                    <ImageView
                        android:id="@+id/ivAiImage"
                        android:layout_width="180dp"
                        android:layout_height="wrap_content"
                        android:maxHeight="180dp"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:layout_margin="6dp"
                        android:visibility="gone" />

                    <!-- AI 消息文本 -->
                    <TextView
                        android:id="@+id/tvAiMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="4dp"
                        android:textColor="@color/bubble_ai_text"
                        android:textSize="15sp"
                        android:lineSpacingExtra="3dp"
                        android:textIsSelectable="true" />

                    <!-- 模型名（小字，气泡底部） -->
                    <TextView
                        android:id="@+id/tvModelTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:textSize="9sp"
                        android:textColor="@color/timestamp_light"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvAiTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginStart="4dp"
                android:textSize="10sp"
                android:textColor="@color/timestamp_light" />

        </LinearLayout>
    </LinearLayout>

</FrameLayout>
</LinearLayout>
