<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="new_chat"
        android:enabled="true"
        android:icon="@android:drawable/ic_menu_edit"
        android:shortcutShortLabel="@string/shortcut_new_chat"
        android:shortcutLongLabel="@string/shortcut_new_chat_long">
        <intent
            android:action="ai.openclaw.poc.NEW_CHAT"
            android:targetPackage="ai.openclaw.poc"
            android:targetClass="ai.openclaw.poc.MainActivity" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>
    <shortcut
        android:shortcutId="voice_input"
        android:enabled="true"
        android:icon="@android:drawable/ic_btn_speak_now"
        android:shortcutShortLabel="@string/shortcut_voice"
        android:shortcutLongLabel="@string/shortcut_voice_long">
        <intent
            android:action="ai.openclaw.poc.VOICE_INPUT"
            android:targetPackage="ai.openclaw.poc"
            android:targetClass="ai.openclaw.poc.MainActivity" />
    </shortcut>
</shortcuts>
